# =========================
# Server
# =========================
PORT=5000
NODE_ENV=development
API_BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# =========================
# Database
# =========================
MONGODB_URI=mongodb://localhost:27017/gdg-mmmut

# =========================
# Auth / Session
# =========================
JWT_SECRET=replace-with-strong-random-secret
JWT_EXPIRE=7d
SESSION_SECRET=replace-with-strong-random-session-secret

# IMMERSE uses a dedicated secret in production
IMMERSE_JWT_SECRET=replace-with-strong-random-immerse-secret

# =========================
# OAuth
# =========================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:5000/api/auth/github/callback

# =========================
# Email
# =========================
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=team@gdg.mmmut.app
RESEND_FROM_NAME=GDG MMMUT

# Optional IMMERSE-specific sender/key override
IMMERSE_RESEND_API_KEY=your-immerse-resend-api-key
IMMERSE_FROM_EMAIL=team@immerse.mmmut.app
IMMERSE_FROM_NAME=IMMERSE 2026 - MMMUT
IMMERSE_FROM_DOMAIN=immerse.mmmut.app

# Enforce Resend-only OTP delivery (recommended true in production)
REQUIRE_RESEND_FOR_OTP=false

MAIL_TO=admin@example.com

# Optional SMTP fallback
NODEMAILER_EMAIL=your-email@example.com
NODEMAILER_PASSWORD=your-email-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password

# =========================
# Feature Flags
# =========================
ENABLE_SETUP_ROUTES=false
ENABLE_NOTIFICATIONS_MODULE=false

# =========================
# Script-only Optional Vars
# =========================
IMMERSE_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
IMMERSE_BOOTSTRAP_ADMIN_PASSWORD=change-this-password
IMMERSE_BOOTSTRAP_ADMIN_NAME=Immerse Admin

IMMERSE_SUPER_ADMIN_EMAIL=admin@example.com
IMMERSE_SUPER_ADMIN_PASSWORD=change-this-password
IMMERSE_SUPER_ADMIN_NAME=Super Admin

GDG_PRESET_SUPER_ADMIN_PASSWORD=change-this-password
GDG_PRESET_ADMIN_PASSWORD=change-this-password
GDG_PRESET_EVENT_MANAGER_PASSWORD=change-this-password
